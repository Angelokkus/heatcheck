{
  "name": "faceit-form-level",
  "version": "0.1.0",
  "description": "Cross-browser MV3 extension showing extended FACEIT (CS2) player stats and a Form Level in the match room.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build/build.mjs",
    "watch": "node build/build.mjs --watch",
    "probe": "tsx scripts/probe-api.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/node": "^20.14.12",
    "@types/webextension-polyfill": "^0.12.1",
    "adm-zip": "^0.6.0",
    "esbuild": "^0.23.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "dependencies": {
    "sharp": "^0.35.3",
    "webextension-polyfill": "^0.12.0"
  }
}
