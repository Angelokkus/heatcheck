{
  "manifest_version": 3,
  "name": "Heatcheck — FACEIT CS2 Stats",
  "version": "0.1.0",
  "description": "Extended CS2 stats, a live Form Level, encounters, team odds & smurf checks in the FACEIT match room. No trackers.",
  "author": "Angelok",
  "permissions": ["storage"],
  "host_permissions": ["https://open.faceit.com/*"],
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "background": {
    "scripts": ["background/index.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://www.faceit.com/*"],
      "js": ["content/index.js"],
      "css": ["styles/badge.css"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "popup/popup.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "Heatcheck",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "faceit-form-level@local.dev",
      "strict_min_version": "115.0"
    }
  }
}
